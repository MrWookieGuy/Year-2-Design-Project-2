/* =========================================================================
 * INTERPLANETARY ROBOT - MISSION PHASE 11 (YELLOW CAN SECURE)
 * Task: ... -> Approach Yellow Can -> Open -> 18.5cm Advance -> Grab
 * ========================================================================= */

#include <Wire.h>
#include <MobaTools.h>

// ==========================================
// 1. PIN & ADDRESS DEFINITIONS
// ==========================================
#define MD25ADDRESS 0x58
#define SPEED1 (byte)0x00
#define SPEED2 0x01
#define RESETENCODERS 0x10
#define MODESELECTOR 0xF

#define trigLeft 3            
#define echoLeft 2            
#define trigRight 9           
#define echoRight 8           
#define SERVO_PIN 10          

// ==========================================
// 2. TUNING CONSTANTS
// ==========================================
const int STOP              = 128; 
const int DASH_SPEED        = 25;  
const int SEARCH_BASE_SPEED = 15;  
const int TURN_SPEED        = 18; 
const int SCAN_SPEED        = 5;  
const int REVERSE_SPEED     = 25; 
const int CALIBRATE_SPEED   = 25; 

const int SCAN_DIST         = 180; 
const int HALT_DIST         = 22;  
const int WALL_STOP_DIST    = 20;  

const float TICKS_PER_MM    = 1.0; 
const long TICKS_90_TURN    = 215; 

const float Kp              = 0.3;  
const int MAX_STEER_ADJUST  = 8;    

const int CLOSE_ANGLE       = 110;   
const int OPEN_ANGLE        = 180;
const int SERVO_SPEED       = 10; 

// ==========================================
// 3. OBJECTS & STATE MACHINE
// ==========================================
MoToServo gripperServo; 

enum RobotState {
  STATE_STARTUP,           
  STATE_INITIAL_ADVANCE,   
  STATE_SWEEP,             
  STATE_APPROACH,          
  STATE_PREP_GRIP,         
  STATE_FINAL_INCHES,      
  STATE_SECURE_CAN,        
  STATE_POST_GRAB_ADVANCE, 
  STATE_TURN_CW_INITIAL,   
  STATE_REVERSE_INITIAL_WALL,   
  STATE_DRIVE_OFF_WALL,    
  STATE_TURN_ACW,          
  STATE_DRIVE_TO_DROP,     
  STATE_RELEASE_CAN,       
  STATE_RETREAT,           
  STATE_TURN_CW_RECENTRE,  
  STATE_WALL_RECENTRE,     
  STATE_MOVE_TO_YELLOW,    
  STATE_CLOSE_FOR_HUNT,    
  STATE_SWEEP_YELLOW,      
  STATE_APPROACH_YELLOW,   
  STATE_PREP_YELLOW_GRIP,   // New: Open for second can
  STATE_FINAL_INCHES_YELLOW,// New: 18.5cm advance
  STATE_SECURE_YELLOW_CAN,  // New: Grab second can
  STATE_COMPLETE           
};

RobotState currentState = STATE_STARTUP;

void setup() {
  Serial.begin(9600); 
  Wire.begin();       

  pinMode(trigLeft,  OUTPUT); pinMode(echoLeft,  INPUT);
  pinMode(trigRight, OUTPUT); pinMode(echoRight, INPUT);

  gripperServo.attach(SERVO_PIN);
  gripperServo.setSpeed(SERVO_SPEED); 
  
  delay(2000);
  slowServoMove(OPEN_ANGLE);
  delay(500); 
  slowServoMove(CLOSE_ANGLE);

  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(MODESELECTOR); 
  Wire.write(0);            
  Wire.endTransmission();

  encoderReset(); 
  Serial.println("SYSTEM READY. Phase 11: Yellow Can Secure.");
}

void loop() {
  switch (currentState) {
    case STATE_STARTUP:
      encoderReset();
      delay(100); 
      currentState = STATE_INITIAL_ADVANCE; 
      break;

    case STATE_INITIAL_ADVANCE:
      if (driveDistance(700, DASH_SPEED)) { 
        currentState = STATE_SWEEP; 
      }
      break;

    case STATE_SWEEP:
      set_speed(STOP + TURN_SPEED, STOP - TURN_SPEED);
      if (checkForObject()) {
        set_speed(STOP, STOP);
        delay(500); 
        currentState = STATE_APPROACH; 
      }
      break;

    case STATE_APPROACH:
      if (performDifferentialApproach()) {
        set_speed(STOP, STOP);
        encoderReset();
        currentState = STATE_PREP_GRIP; 
      }
      break;

    case STATE_PREP_GRIP:
      delay(300); 
      slowServoMove(OPEN_ANGLE);
      delay(500); 
      currentState = STATE_FINAL_INCHES;
      break;

    case STATE_FINAL_INCHES:
      if (driveDistance(180, SEARCH_BASE_SPEED)) {
        currentState = STATE_SECURE_CAN;
      }
      break;

    case STATE_SECURE_CAN:
      delay(300); 
      slowServoMove(CLOSE_ANGLE);
      delay(500); 
      currentState = STATE_POST_GRAB_ADVANCE;
      break;

    case STATE_POST_GRAB_ADVANCE:
      if (driveDistance(50, SEARCH_BASE_SPEED)) {
        encoderReset();
        delay(100);
        currentState = STATE_TURN_CW_INITIAL;
      }
      break;

    case STATE_TURN_CW_INITIAL:
      if (turnInPlace(TICKS_90_TURN, TURN_SPEED, true)) {
        encoderReset();
        delay(100);
        currentState = STATE_REVERSE_INITIAL_WALL;
      }
      break;

    case STATE_REVERSE_INITIAL_WALL:
      if (driveDistance(-500, REVERSE_SPEED)) {
        encoderReset();
        delay(100);
        currentState = STATE_DRIVE_OFF_WALL;
      }
      break;

    case STATE_DRIVE_OFF_WALL:
      if (driveDistance(100, SEARCH_BASE_SPEED)) {
        encoderReset();
        delay(100);
        currentState = STATE_TURN_ACW;
      }
      break;

    case STATE_TURN_ACW:
      if (turnInPlace(TICKS_90_TURN, TURN_SPEED, false)) {
        encoderReset();
        delay(100);
        currentState = STATE_DRIVE_TO_DROP;
      }
      break;

    case STATE_DRIVE_TO_DROP: 
    {
      int distL = readSensor(trigLeft, echoLeft);
      delay(20);
      int distR = readSensor(trigRight, echoRight);
      
      if ((distL > 0 && distL <= WALL_STOP_DIST) || (distR > 0 && distR <= WALL_STOP_DIST)) {
        set_speed(STOP, STOP);
        currentState = STATE_RELEASE_CAN;
      } else {
        set_speed(STOP + DASH_SPEED, STOP + DASH_SPEED);
      }
      break;
    }

    case STATE_RELEASE_CAN:
      delay(500);
      slowServoMove(OPEN_ANGLE);
      delay(500);
      encoderReset();
      currentState = STATE_RETREAT;
      break;

    case STATE_RETREAT:
      if (driveDistance(-150, REVERSE_SPEED)) {
        encoderReset();
        delay(100);
        currentState = STATE_TURN_CW_RECENTRE;
      }
      break;

    case STATE_TURN_CW_RECENTRE:
      if (turnInPlace(TICKS_90_TURN, TURN_SPEED, true)) {
        currentState = STATE_WALL_RECENTRE;
      }
      break;

    case STATE_WALL_RECENTRE:
      set_speed(STOP - CALIBRATE_SPEED, STOP - CALIBRATE_SPEED);
      delay(6500); 
      set_speed(STOP, STOP);
      encoderReset();
      currentState = STATE_MOVE_TO_YELLOW;
      break;

    case STATE_MOVE_TO_YELLOW:
      if (driveDistance(150, SEARCH_BASE_SPEED)) {
        encoderReset(); 
        currentState = STATE_CLOSE_FOR_HUNT;
      }
      break;

    case STATE_CLOSE_FOR_HUNT:
      slowServoMove(CLOSE_ANGLE);
      delay(300);
      currentState = STATE_SWEEP_YELLOW;
      break;

    case STATE_SWEEP_YELLOW:
      set_speed(STOP + SCAN_SPEED, STOP - SCAN_SPEED);
      if (checkForObject()) {
        set_speed(STOP, STOP);
        delay(500);
        currentState = STATE_APPROACH_YELLOW;
      } 
      else if (abs(getEncoder()) >= TICKS_90_TURN) {
        set_speed(STOP, STOP);
        currentState = STATE_COMPLETE;
      }
      break;

    case STATE_APPROACH_YELLOW:
      if (performDifferentialApproach()) {
        set_speed(STOP, STOP);
        encoderReset();
        currentState = STATE_PREP_YELLOW_GRIP;
      }
      break;

    case STATE_PREP_YELLOW_GRIP:
      delay(300);
      slowServoMove(OPEN_ANGLE);
      delay(500);
      currentState = STATE_FINAL_INCHES_YELLOW;
      break;

    case STATE_FINAL_INCHES_YELLOW:
      // Driving 18.5cm (185mm) to seat the second can
      if (driveDistance(185, SEARCH_BASE_SPEED)) {
        currentState = STATE_SECURE_YELLOW_CAN;
      }
      break;

    case STATE_SECURE_YELLOW_CAN:
      delay(300);
      slowServoMove(CLOSE_ANGLE);
      delay(500);
      Serial.println("Can #2 Secured.");
      currentState = STATE_COMPLETE;
      break;

    case STATE_COMPLETE:
      set_speed(STOP, STOP);
      break;
  }
}

// ==========================================
// 4. HELPER FUNCTIONS
// ==========================================

void slowServoMove(int targetAngle) {
  gripperServo.write(targetAngle); 
  while (gripperServo.moving() > 0) {
    delay(10); 
  }
}

bool driveDistance(long distanceMM, int speed) {
  long target = abs(distanceMM * TICKS_PER_MM); 
  if (abs(getEncoder()) < target) {
    if (distanceMM > 0) set_speed(STOP + speed, STOP + speed); 
    else set_speed(STOP - speed, STOP - speed); 
    return false;
  } else {
    set_speed(STOP, STOP); 
    encoderReset();        
    return true;  
  }
}

bool turnInPlace(long ticks, int speed, bool clockwise) {
  if (abs(getEncoder()) < ticks) {
    if (clockwise) set_speed(STOP + speed, STOP - speed);
    else set_speed(STOP - speed, STOP + speed);
    return false;
  } else {
    set_speed(STOP, STOP);
    encoderReset();
    return true;
  }
}

bool checkForObject() {
  int dL = readSensor(trigLeft, echoLeft); 
  delay(20);                               
  int dR = readSensor(trigRight, echoRight); 
  return ((dL > 2 && dL < SCAN_DIST) || (dR > 2 && dR < SCAN_DIST));
}

bool performDifferentialApproach() {
  int dL = readSensor(trigLeft, echoLeft);
  delay(20); 
  int dR = readSensor(trigRight, echoRight);

  if ((dL > 0 && dL <= HALT_DIST) || (dR > 0 && dR <= HALT_DIST)) return true; 

  int error = dL - dR;  
  int leftMotor  = SEARCH_BASE_SPEED;
  int rightMotor = SEARCH_BASE_SPEED;

  if (dL < SCAN_DIST && dR < SCAN_DIST) {
    int steeringAdjust = constrain((int)(error * Kp), -MAX_STEER_ADJUST, MAX_STEER_ADJUST);
    leftMotor  += steeringAdjust;
    rightMotor -= steeringAdjust;
  } else if (dL > SCAN_DIST && dR < SCAN_DIST) {
    leftMotor  = SEARCH_BASE_SPEED + 4;
    rightMotor = SEARCH_BASE_SPEED - 6;
  } else if (dR > SCAN_DIST && dL < SCAN_DIST) {
    leftMotor  = SEARCH_BASE_SPEED - 6;
    rightMotor = SEARCH_BASE_SPEED + 4;
  } else {
    leftMotor  = SEARCH_BASE_SPEED - 3;
    rightMotor = SEARCH_BASE_SPEED - 3;
  }

  set_speed(STOP + leftMotor, STOP + rightMotor);
  return false; 
}

int readSensor(int trig, int echo) {
  digitalWrite(trig, LOW);  delayMicroseconds(2);
  digitalWrite(trig, HIGH); delayMicroseconds(10);
  digitalWrite(trig, LOW);
  long duration = pulseIn(echo, HIGH, 30000);
  if (duration == 0) return 999;
  return duration * 0.034 / 2; 
}

void set_speed(int s1, int s2) {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(SPEED1); Wire.write(constrain(s1, 0, 255)); 
  Wire.endTransmission();
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(SPEED2); Wire.write(constrain(s2, 0, 255));
  Wire.endTransmission();
}

void encoderReset() {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(RESETENCODERS); Wire.write(0x20); 
  Wire.endTransmission();
}

long getEncoder() {
  Wire.beginTransmission(MD25ADDRESS);
  Wire.write(0x02); 
  Wire.endTransmission();
  Wire.requestFrom(MD25ADDRESS, 4);
  if (Wire.available() < 4) return 0; 
  long pos  = (long)Wire.read() << 24;
  pos      += (long)Wire.read() << 16;
  pos      += (long)Wire.read() << 8;
  pos      += (long)Wire.read();
  return pos;
}
